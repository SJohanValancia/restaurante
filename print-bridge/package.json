{
  "name": "jc-rt-print-bridge",
  "version": "1.0.0",
  "description": "Middleware de impresión local para JC-RT",
  "main": "server.js",
  "bin": "server.js",
  "pkg": {
    "assets": [
      "node_modules/node-thermal-printer/driver/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node server.js",
    "build": "pkg ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-thermal-printer": "^4.4.1"
  }
}
